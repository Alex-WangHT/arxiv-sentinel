{
  "name": "paper-sniffer-backend",
  "version": "1.0.0",
  "description": "Cloudflare Workers app for tracking and reviewing arXiv papers",
  "type": "module",
  "main": "backend/dist/index.js",
  "types": "backend/dist/index.d.ts",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "tsc -p frontend/tsconfig.json",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc --noEmit -p backend/tsconfig.json",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "dev": "wrangler dev --config backend/wrangler.toml --local --env-file backend/script/config/.dev.vars",
    "dev:all": "powershell -ExecutionPolicy Bypass -File script/local-build-run.ps1",
    "dev:frontend": "wrangler dev --config frontend/wrangler.toml --local --env-file frontend/script/config/.dev.vars",
    "dev:scheduled": "wrangler dev --config backend/wrangler.toml --local --test-scheduled --env-file backend/script/config/.dev.vars",
    "deploy": "wrangler deploy --config backend/wrangler.toml",
    "deploy:frontend": "wrangler deploy --config frontend/wrangler.toml",
    "deploy:local": "bash backend/script/deploy.sh local",
    "deploy:cloud": "bash backend/script/deploy.sh cloud",
    "deploy:frontend:local": "bash frontend/script/deploy.sh local",
    "deploy:frontend:cloud": "bash frontend/script/deploy.sh cloud",
    "local:build-run": "powershell -ExecutionPolicy Bypass -File script/local-build-run.ps1",
    "local:build-run:bash": "bash script/local-build-run.sh",
    "test:all": "bash backend/script/test.sh local",
    "test:local": "bash backend/script/test.sh local",
    "test:cloud": "bash backend/script/test.sh cloud",
    "tail": "wrangler tail --config backend/wrangler.toml"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0",
    "wrangler": "^4.0.0"
  }
}
