{
  "name": "paper-sniffer-backend",
  "version": "1.0.0",
  "description": "Cloudflare Workers and Queues backend for tracking arXiv papers",
  "type": "module",
  "main": "backend/dist/index.js",
  "types": "backend/dist/index.d.ts",
  "scripts": {
    "build": "tsc -p backend/tsconfig.json",
    "typecheck": "tsc --noEmit -p backend/tsconfig.json",
    "dev": "wrangler dev --config backend/wrangler.toml --local",
    "dev:scheduled": "wrangler dev --config backend/wrangler.toml --local --test-scheduled",
    "deploy": "wrangler deploy --config backend/wrangler.toml",
    "tail": "wrangler tail --config backend/wrangler.toml"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0",
    "wrangler": "^4.0.0"
  }
}
